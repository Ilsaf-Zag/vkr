APP_NAME="AZYK Transport"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=azyk_transport
DB_USERNAME=azyk
DB_PASSWORD=azyk

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=azyk
REVERB_APP_KEY=azyk-key
REVERB_APP_SECRET=azyk-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

FILESYSTEM_DISK=public

OCR_SERVICE_URL=http://ocr:8001
OCR_SERVICE_TIMEOUT=180
ODOMETER_GPS_REVIEW_THRESHOLD_KM=5
